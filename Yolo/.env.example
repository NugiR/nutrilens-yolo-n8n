# Path to trained YOLO weights
MODEL_PATH=runs/detect/indonesia-food-v2/weights/best.pt

# Minimum confidence for detections (0.0 - 1.0)
CONF_THRESHOLD=0.35

# Flask server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Comma-separated browser origins allowed to call Flask directly (Laravel APP_URL)
FLASK_CORS_ORIGINS=http://localhost:8000
